# Machine-specific Git overrides.
#
# role:
#   personal = personal laptop/desktop
#   work     = work-managed but shared development setup
#   remote   = disposable remote dev host

{{ if eq .chezmoi.os "darwin" -}}
[credential]
	helper = osxkeychain
{{ else -}}
[credential]
	helper = cache --timeout=43200
{{ end }}

