      "WebFetch(domain:github.com)",
      "Bash(git:*)",
      "Bash(git -C:*)",
      "Bash(gh:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(echo:*)",
      "Bash(printf:*)",
      "Bash(chmod:*)",
      "Bash(curl:*)",
      "Bash(mv:*)",
      "Bash(rm:*)",
      "Bash(touch:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(readlink:*)",
      "Bash(xargs:*)",
      "Bash(pgrep:*)",
